{
  "name": "geu-website",
  "version": "0.1.0",
  "private": true,
  "description": "Static Astro rebuild of https://geunion.dk from the immutable Webstudio export in reference/legacy-export/",
  "type": "module",
  "engines": {
    "node": ">=22.21.0 <23"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "astro check",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:seo": "vitest run --config vitest.seo.config.ts",
    "test:e2e": "playwright test --project=e2e",
    "test:a11y": "playwright test --project=a11y",
    "test:visual": "playwright test --project=visual",
    "check:links": "node scripts/check-links.mjs",
    "check:assets": "node scripts/check-external-assets.mjs",
    "check:dist": "node scripts/check-dist-assets.mjs",
    "validate:html": "html-validate \"dist/**/*.html\"",
    "audit:lighthouse": "node scripts/audit-lighthouse.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run test:seo && npm run validate:html && npm run check:dist && npm run check:links"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/google-calendar": "^6.1.21",
    "astro": "^7.0.7",
    "dompurify": "^3.4.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.7.0",
    "html-validate": "^11.4.0",
    "lighthouse": "^13.4.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
