---
/**
 * Seasonal /minecraft theme: same shell as BaseLayout with the legacy
 * Minecraft font stack, grey page background, pixel header logo, and
 * pixelated panel corners. Font sources are the exact legacy cdnfonts
 * URLs (docs/external-assets.md).
 */
import type { SeoProps } from "../components/seo/SeoHead.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  seo: SeoProps;
}

const { seo } = Astro.props;
---

<BaseLayout seo={seo} theme="minecraft">
  <slot name="hero" slot="hero" />
  <slot />
</BaseLayout>

<style is:global>
  @import url("https://fonts.cdnfonts.com/css/minecrafter-alt");
  @import url("https://fonts.cdnfonts.com/css/minecraftia");
  @import url("https://fonts.cdnfonts.com/css/minecraft-title");

  body.theme-minecraft {
    font-family: Minecraftia, Rubik, Arial, Roboto, sans-serif;
    font-size: 18px;
    background-color: #e7e7e7;
  }

  .theme-minecraft h1 {
    font-family: "Minecrafter Alt", Tanker, sans-serif;
    font-weight: 500;
    font-size: 3.8em;
  }

  .theme-minecraft h2 {
    font-family: "Minecraft Title", Rubik, sans-serif;
    font-weight: 100;
    margin-bottom: 0.3em;
  }

  /* Stepped clip-path corners for the hero panel (legacy .pixel-corners). */
  .theme-minecraft .pixel-corners {
    clip-path: polygon(
      0px calc(100% - 24px),
      6px calc(100% - 24px),
      6px calc(100% - 12px),
      12px calc(100% - 12px),
      12px calc(100% - 6px),
      24px calc(100% - 6px),
      24px 100%,
      calc(100% - 24px) 100%,
      calc(100% - 24px) calc(100% - 6px),
      calc(100% - 12px) calc(100% - 6px),
      calc(100% - 12px) calc(100% - 12px),
      calc(100% - 6px) calc(100% - 12px),
      calc(100% - 6px) calc(100% - 24px),
      100% calc(100% - 24px),
      100% 24px,
      calc(100% - 6px) 24px,
      calc(100% - 6px) 12px,
      calc(100% - 12px) 12px,
      calc(100% - 12px) 6px,
      calc(100% - 24px) 6px,
      calc(100% - 24px) 0px,
      24px 0px,
      24px 6px,
      12px 6px,
      12px 12px,
      6px 12px,
      6px 24px,
      0px 24px
    );
  }
</style>
