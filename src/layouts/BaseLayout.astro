---
/**
 * Shared document shell for every page: head metadata (via SeoHead),
 * global styles, hero slot, main content, and footer.
 *
 * Analytics deviation from the legacy site (prompt 04): GA4 is no longer
 * loaded unconditionally — GoogleAnalytics renders nothing until the team
 * opts in via siteConfig.analytics (src/data/site.ts).
 */
import GoogleAnalytics from "../components/seo/GoogleAnalytics.astro";
import SeoHead from "../components/seo/SeoHead.astro";
import type { SeoProps } from "../components/seo/SeoHead.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import { localAssets } from "../data/local-assets";
import { siteConfig } from "../data/site";
import "../styles/global.css";

interface Props {
  seo: SeoProps;
  theme?: "default" | "minecraft";
}

const { seo, theme = "default" } = Astro.props;
const headerLogo =
  theme === "minecraft" ? localAssets.geuLogoPixel : localAssets.geLogoBig;
---

<!doctype html>
<html lang={seo.lang ?? siteConfig.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="image" href={headerLogo} />
    <SeoHead {...seo} />
    <GoogleAnalytics />
    <slot name="head" />
  </head>
  <body class:list={[{ "theme-minecraft": theme === "minecraft" }]}>
    <slot name="hero" />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  main {
    display: flex;
    flex-direction: column;
    flex: 1 0 auto;
  }
</style>
