---
import { homeCarousel } from "../../data/home";
---

<section
  class="carousel"
  aria-label="GE Union highlights"
  data-carousel
  tabindex="0"
>
  <div class="viewport" data-carousel-viewport>
    <div class="track" data-carousel-track>
      {
        homeCarousel.map((item, index) => (
          <figure
            class="slide"
            data-carousel-slide
            aria-hidden={index !== 0 ? "true" : undefined}
          >
            <img
              src={item.src}
              alt={item.caption}
              width="900"
              height="600"
              loading="lazy"
              draggable="false"
            />
            <figcaption>{item.caption}</figcaption>
          </figure>
        ))
      }
    </div>
  </div>
  <button
    class="control previous"
    type="button"
    aria-label="Previous image"
    data-carousel-previous>‹</button
  >
  <button
    class="control next"
    type="button"
    aria-label="Next image"
    data-carousel-next>›</button
  >
  <p class="status visually-hidden" aria-live="polite" data-carousel-status></p>
</section>

<script>
  import { initCarousels } from "../../scripts/carousel";
  initCarousels();
</script>

<style>
  .carousel {
    position: relative;
    width: 100%;
    margin: 40px 0 90px;
    overflow: hidden;
    touch-action: pan-y;
  }
  .viewport {
    overflow: hidden;
  }
  .track {
    display: flex;
    gap: 14px;
    transform: translateX(calc(-1 * var(--slide-index, 0) * (42vw + 14px)));
    transition: transform 0.45s ease;
  }
  .slide {
    flex: 0 0 42vw;
    margin: 0;
    text-align: center;
  }
  .slide img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 8px;
    user-select: none;
  }
  figcaption {
    margin-top: 5px;
    font-size: 0.82rem;
  }
  .control {
    position: absolute;
    top: 42%;
    display: grid;
    place-items: center;
    width: 36px;
    height: 44px;
    border: 0;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.9);
    color: var(--front-1);
    font-size: 34px;
    cursor: pointer;
  }
  .previous {
    left: 8px;
  }
  .next {
    right: 8px;
  }
  @media (prefers-reduced-motion: reduce) {
    .track {
      transition: none;
    }
  }
  @media (max-width: 767px) {
    .carousel {
      margin: 30px 0 75px;
    }
    .track {
      transform: translateX(calc(-1 * var(--slide-index, 0) * (68vw + 8px)));
      gap: 8px;
    }
    .slide {
      flex-basis: 68vw;
    }
  }
</style>
