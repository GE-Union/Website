---
/**
 * Burger button + native <dialog> drawer for viewports below 480px.
 * Mirrors the legacy Radix drawer's content (heading "Navigation",
 * description, seven links) while getting labeling, Escape, focus
 * management, and background blocking from the platform.
 */
import { mobileMenuLinks } from "../../data/navigation";
---

<button
  type="button"
  class="burger"
  data-menu-open
  aria-haspopup="dialog"
  aria-expanded="false"
>
  <span class="visually-hidden">Open navigation menu</span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 16 16"
    width="100%"
    height="100%"
    aria-hidden="true"
  >
    <path
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5px"
      d="M2.667 8h10.666M2.667 4h10.666M2.667 12h10.666"></path>
  </svg>
</button>

<dialog
  class="menu-dialog"
  data-menu-dialog
  aria-labelledby="mobile-menu-title"
>
  <nav aria-label="Site">
    <p class="menu-description">Find any page you want on the site</p>
    <h2 class="menu-title" id="mobile-menu-title">Navigation</h2>
    <ul class="menu-links" role="list">
      {
        mobileMenuLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
  <button type="button" class="menu-close" data-menu-close>
    <span class="visually-hidden">Close menu</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 16 16"
      width="100%"
      height="100%"
      aria-hidden="true"
    >
      <path
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12.5 3 3 12.5M3 3l9.5 9.5"></path>
    </svg>
  </button>
</dialog>

<script>
  import { initMobileMenu } from "../../scripts/mobile-menu";

  const burger = document.querySelector<HTMLButtonElement>("[data-menu-open]");
  const dialog =
    document.querySelector<HTMLDialogElement>("[data-menu-dialog]");
  if (burger && dialog) initMobileMenu(burger, dialog);
</script>

<style>
  .burger {
    display: none;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
    width: 2.5rem;
    padding: 0 0.375rem;
    background-color: transparent;
    border: none;
    color: var(--background);
    cursor: pointer;
  }

  @media (max-width: 479px) {
    .burger {
      display: inline-flex;
    }
  }

  /* Left-hand drawer panel, sized like the legacy dialog content. */
  .menu-dialog {
    margin: 0;
    margin-right: auto;
    height: 100dvh;
    max-height: 100dvh;
    width: 85%;
    max-width: 85vw;
    border: 1px solid rgb(226 232 240);
    padding: 1.5rem;
    background-color: #fff;
    box-shadow:
      0 10px 15px -3px #0000001a,
      0 4px 6px -4px #0000001a;
    color: var(--front-1);
  }

  .menu-dialog::backdrop {
    background-color: #00000029;
    backdrop-filter: blur(3px);
  }

  .menu-dialog nav {
    margin-top: 30px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .menu-description {
    color: var(--front-2);
    font-size: 13px;
    line-height: 1.3;
    margin: 0;
  }

  .menu-title {
    margin: 0;
  }

  .menu-links {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 4px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  .menu-links a {
    font-weight: 500;
    font-size: 20px;
    color: var(--front-2);
    text-decoration: none;
    padding: 10px 5px;
  }

  .menu-links a:hover {
    color: var(--front-1);
  }

  .menu-close {
    position: absolute;
    right: 1.5rem;
    top: 1.5rem;
    height: 1.5rem;
    width: 1.5rem;
    padding: 0;
    border: none;
    border-radius: 0.125rem;
    background: none;
    color: var(--front-1);
    cursor: pointer;
  }
</style>
