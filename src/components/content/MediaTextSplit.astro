---
interface Props {
  reverse?: boolean;
  class?: string;
}

const { reverse = false, class: className } = Astro.props;
---

<section class:list={["media-text-split", className, { reverse }]}>
  <div class="media"><slot name="media" /></div>
  <div class="copy"><slot /></div>
</section>

<style>
  .media-text-split {
    display: grid;
    grid-template-columns: minmax(160px, 0.7fr) minmax(0, 1.7fr);
    align-items: center;
    gap: 48px;
  }
  .reverse {
    grid-template-columns: minmax(0, 1.7fr) minmax(160px, 0.7fr);
  }
  .reverse .media {
    order: 2;
  }
  .media :global(img) {
    display: block;
    max-width: 100%;
    max-height: 260px;
    margin: auto;
    object-fit: contain;
  }
  @media (max-width: 600px) {
    .media-text-split,
    .reverse {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .reverse .media {
      order: 0;
    }
    .media :global(img) {
      max-height: 180px;
    }
  }
</style>
