---
// Temporary route shell; page sections arrive in prompt 09. The seasonal
// indexing decision lives in the SEO matrix: noindex until the owner sets
// siteConfig.minecraftEventActive (src/data/site.ts).
import PageHero from "../components/layout/PageHero.astro";
import { getPageSeo } from "../data/seo-matrix";
import MinecraftLayout from "../layouts/MinecraftLayout.astro";
---

<MinecraftLayout seo={getPageSeo("/minecraft")}>
  <PageHero
    slot="hero"
    theme="minecraft"
    title="Minecraft month"
    subtitle="Join the rest of GE for mining and crafting!"
  />
</MinecraftLayout>
